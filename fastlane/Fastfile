default_platform(:ios)

platform :ios do

  desc "Build and upload to TestFlight"
  lane :beta do
    app_id = "edu.cmu.wiselab.wisescan-ios"

    # Authenticate with the App Store Connect API key (capture it so the signing + upload steps
    # below reuse it — no interactive Apple ID / Xcode account login required).
    api_key = app_store_connect_api_key(
      key_id: ENV["APP_STORE_CONNECT_API_KEY_KEY_ID"],
      issuer_id: ENV["APP_STORE_CONNECT_API_KEY_ISSUER_ID"],
      key_content: ENV["APP_STORE_CONNECT_API_KEY_KEY"],
      is_key_content_base64: true
    )

    # Increment build number using the latest TestFlight build number + 1
    latest_build = latest_testflight_build_number(
      api_key: api_key,
      app_identifier: app_id
    )
    increment_build_number(
      build_number: latest_build + 1,
      xcodeproj: "wisescan-ios.xcodeproj"
    )

    # Code signing via the API key — fixes the export failure that occurred when signing relied on
    # a logged-in Xcode account ("No Accounts" / "No signing certificate iOS Distribution found").
    # get_certificates installs an Apple Distribution cert (creates one if this machine has none);
    # get_provisioning_profile downloads/creates the App Store profile. The export then signs
    # manually against that profile. (Requires the API key to have App Manager or Admin role.)
    get_certificates(api_key: api_key)
    get_provisioning_profile(api_key: api_key, app_identifier: app_id)

    # Build the app (archive + export). Export is manual, using the profile fetched above.
    build_app(
      scheme: "wisescan-ios",
      export_method: "app-store",
      xcargs: "-allowProvisioningUpdates",
      export_options: {
        signingStyle: "manual",
        provisioningProfiles: {
          app_id => lane_context[SharedValues::SIGH_NAME]
        }
      }
    )

    # Upload to TestFlight with custom beta feedback email
    upload_to_testflight(
      api_key: api_key,
      skip_waiting_for_build_processing: true,
      beta_app_feedback_email: "arenaxr@andrew.cmu.edu",
      changelog: "See https://github.com/WiseLabCMU/wisescan-ios/blob/main/CHANGELOG.md for details."
    )
  end

  desc "Build only (no upload) — for local validation"
  lane :build do
    build_app(
      scheme: "wisescan-ios",
      export_method: "app-store",
      xcargs: "-allowProvisioningUpdates",
      skip_archive: false
    )
  end

  desc "Generate App Store screenshots via Simulator UI tests"
  lane :screenshots do
    snapshot(
      scheme: "wisescan-iosUITests",
      output_directory: "./fastlane/screenshots",
      clean: false,
      stop_after_first_error: true
    )
  end

end
